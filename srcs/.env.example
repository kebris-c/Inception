# =============================================================================
# Inception — Environment variables template
# =============================================================================
# COPY to .env and fill in:  cp .env.example .env
# NEVER commit srcs/.env with real values.
# Passwords belong in ../secrets/*.txt (Docker secrets), NOT here.
# =============================================================================

# --- Domain (subject: must be <login>.42.fr) ---
DOMAIN_NAME=your_login.42.fr

# --- MariaDB (non-secret identifiers) ---
MYSQL_DATABASE=wordpress
MYSQL_USER=wpuser
# MYSQL_PASSWORD → read from Docker secret db_password
# MYSQL_ROOT_PASSWORD → read from Docker secret db_root_password

# --- WordPress database connection ---
WORDPRESS_DB_HOST=mariadb
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wpuser
# WORDPRESS_DB_PASSWORD → from secret

# --- WordPress install (first run) ---
WORDPRESS_URL=https://your_login.42.fr
WORDPRESS_TITLE=Inception
WORDPRESS_ADMIN_USER=siteowner
# WORDPRESS_ADMIN_PASSWORD → from secret or separate secret file
WORDPRESS_ADMIN_EMAIL=you@student.42.fr

# --- Second WordPress user (subject: 2 users required) ---
WORDPRESS_SECOND_USER=editor
WORDPRESS_SECOND_EMAIL=editor@student.42.fr
WORDPRESS_SECOND_ROLE=editor

# --- Optional: base image version pins (no "latest" tag) ---
# MARIADB_VERSION=10.11
# PHP_VERSION=8.2
# NGINX_VERSION=1.25
